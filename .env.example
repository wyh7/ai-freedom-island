BAILIAN_API_KEY=your_bailian_api_key_here   # Qwen / DeepSeek / GLM / MiniMax / Kimi (Aliyun Bailian)
YUNHE_API_KEY=your_yunhe_api_key_here       # GPT (Yunhe/WenWen proxy)
JINGZHE_API_KEY=your_jingzhe_api_key_here   # Gemini (UniAPI proxy)
JD_API_KEY=your_jd_api_key_here             # Claude (JD Cloud proxy)

# --- How to get each key ---
#
# BAILIAN_API_KEY
#   Sign up at: https://bailian.console.aliyun.com
#   Create an API Key under "API Keys" section
#   Supports: qwen-plus, qwen-turbo, qwen-max, deepseek-v3, deepseek-r1, glm-5, kimi-k2.5
#
# YUNHE_API_KEY
#   GPT proxy service, OpenAI-compatible endpoint
#   Supports: gpt-4.1, gpt-5
#
# JINGZHE_API_KEY
#   UniAPI Gemini proxy: https://uniapi.io
#   Supports: gemini-2.5-flash
#
# JD_API_KEY
#   JD Cloud Claude proxy
#   Supports: claude-sonnet-4-6, claude-3-5-haiku-20241022

# --- Running without all keys ---
# You only need the key for the model you want to use.
# Example: only Bailian key needed to run Qwen or DeepSeek experiments.
#
#   python run.py --world my_world --model qwen-plus --days 15
